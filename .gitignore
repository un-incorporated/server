# Rust
/target/
**/*.rs.bk
# Cargo.lock is COMMITTED for binary crates (uninc-proxy, chain-engine,
# observer) so docker builds produce byte-identical artifacts and the
# release-docker.yml workflow can reproduce a tagged build.

# Environment
.env
.env.local
*.pem
*.key
*.crt

# Data
/data/
chain-data/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Terraform
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/**/*.tfvars
!terraform/**/*.tfvars.example
terraform/**/.terraform.lock.hcl

# Docker
docker/config/.env
