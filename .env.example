# ===========================================================================
# Unincorporated Server — Environment Variables
# Copy this to .env and fill in your values.
# ===========================================================================

# --- Database credentials ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mydb

MONGO_USER=appuser
MONGO_PASSWORD=change-me
MONGO_DB=mydb

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# --- Admin credentials (for the proxy to classify as ADMIN) ---
ADMIN_POSTGRES_USER=admin
ADMIN_POSTGRES_PASSWORD=change-me

# --- App credentials (for the proxy to classify as APP / passthrough) ---
APP_POSTGRES_USER=app_user
APP_POSTGRES_PASSWORD=change-me

# --- Chain API (transparency read endpoint on the proxy) ---
# HS256 shared secret. The customer's app backend signs short-lived JWTs
# with this value and the proxy verifies them on :9091/api/v1/chain/*.
# Treat it like a Stripe API key — per-deployment, rotate if it ever leaks.
JWT_SECRET=change-me-to-a-random-secret

# Host-side ports for the two HTTP listeners. The container side is fixed
# at 9090/9091 (hard-coded in uninc-common/src/config.rs); these just let
# you remap on the host if you need to.
PROXY_HEALTH_PORT=9090
PROXY_CHAIN_API_PORT=9091

# --- NATS ---
NATS_URL=nats://nats:4222

# --- Chain engine + Chain API (BOTH sides must see the same values) ---
# CHAIN_SERVER_SALT is fed to SHA-256 along with user_id to derive the
# on-disk chain directory. If the chain-engine writer and the proxy reader
# ever disagree on this value, /api/v1/chain/u/:id/* 404s every user.
# DO NOT rotate after any entries have been written — existing chain
# directories become unreachable (effectively data loss).
CHAIN_STORAGE_PATH=/data/chains
CHAIN_SERVER_SALT=change-me-to-a-random-string

# --- SMTP (for email digest notifications) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=transparency@example.com
